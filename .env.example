# ---------- 通用 ----------
PROJECT_NAME=Flow2API
ENVIRONMENT=development
# 逗号分隔的允许跨域来源
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---------- 安全 ----------
# 生产环境务必替换为随机长字符串: python -c "import secrets;print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE_ME_super_secret_key_for_jwt_signing
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# ---------- 数据库 ----------
POSTGRES_USER=flow
POSTGRES_PASSWORD=flow_pass
POSTGRES_DB=flow2api
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ---------- 对象存储 (MinIO / S3) ----------
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=flow2api
S3_REGION=us-east-1

# ---------- 初始管理员 (seed 脚本使用) ----------
FIRST_ADMIN_EMAIL=admin@flow2api.com
FIRST_ADMIN_PASSWORD=admin12345

# ---------- FLOW 适配层 ----------
# 对 FLOW 上游的全局最大并发(账号池总闸门)
FLOW_GLOBAL_CONCURRENCY=8
# 单账号最大并发
FLOW_PER_ACCOUNT_CONCURRENCY=2
# FLOW 请求超时(秒)
FLOW_REQUEST_TIMEOUT=120
# 出视频轮询最大等待(秒)
FLOW_VIDEO_MAX_WAIT=600

# ---------- 额度默认值 ----------
DEFAULT_DAILY_IMAGE_QUOTA=200
DEFAULT_DAILY_VIDEO_QUOTA=20
# 单用户每分钟最大请求数
USER_RATE_LIMIT_PER_MIN=30

# ---------- 前端 ----------
NEXT_PUBLIC_API_BASE=http://localhost:8000
NEXT_PUBLIC_WS_BASE=ws://localhost:8000
